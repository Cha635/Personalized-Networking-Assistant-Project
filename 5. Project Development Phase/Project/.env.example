# ─────────────────────────────────────────────────────────────────────────────
# Personalized Networking Assistant – Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── AI Model Selection ────────────────────────────────────────────────────────
# DistilBERT model used for zero-shot theme classification
EVENT_ANALYSIS_MODEL=typeform/distilbert-base-uncased-mnli

# GPT-2 Small model used for conversation-starter generation
TEXT_GENERATOR_MODEL=gpt2

# ── External APIs ─────────────────────────────────────────────────────────────
# Wikipedia REST API base URL (no auth required)
FACT_CHECK_API=https://en.wikipedia.org/api/rest_v1/page/summary

# ── Server Configuration ──────────────────────────────────────────────────────
# FastAPI backend URL consumed by the Streamlit frontend
BACKEND_URL=http://127.0.0.1:8000

# ── Google Gemini (Future Enhancement) ───────────
# GEMINI_API_KEY=your_google_gemini_api_key_here
